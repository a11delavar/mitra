# Rebuilt inside the image — never copy host artifacts/deps in.
node_modules
**/node_modules
out
out_test
dist

# Local data / secrets must not leak into the image.
data
**/.env
*.sqlite

# VCS, CI, editor, docs.
.git
.github
.vscode
.idea
*.md
# …except the changelog — it's a runtime asset now (the What's-New dialog serves it; see
# src/backend/changelog.ts), copied into the image by the Dockerfile.
!CHANGELOG.md

# Misc
.DS_Store
npm-debug.log*
